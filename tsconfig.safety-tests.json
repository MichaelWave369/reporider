{
  "compilerOptions": {
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": ".safety-test-build"
  },
  "include": [
    "src/types.ts",
    "src/lib/safetyScan.ts",
    "test/**/*.ts"
  ]
}
